rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /toolHistory/{historyId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    match /tools/{toolSlug} {
      allow read: if true;
      allow write: if false;
    }

    // Per-tool view counters. Written only via the Admin SDK (server route);
    // public read so popularity can be surfaced later.
    match /toolStats/{toolSlug} {
      allow read: if true;
      allow write: if false;
    }

    match /adminConfig/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /subscriptions/{subId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false;
    }
  }
}
